# Read two numbers
echo "Enter first number:"
read num1

echo "Enter second number:"
read num2

# Perform arithmetic operations
sum=$((num1 + num2))
sub=$((num1 - num2))
mul=$((num1 * num2))

# Division check
if [ $num2 -ne 0 ]
then
    div=$((num1 / num2))
else
    div="Undefined (division by zero)"
fi

# Display results
echo "Addition: $sum"
echo "Subtraction: $sub"
echo "Multiplication: $mul"
echo "Division: $div"
